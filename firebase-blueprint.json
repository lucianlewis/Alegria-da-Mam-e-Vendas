{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "seller"] }
      },
      "required": ["uid", "email"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A sales entry",
      "type": "object",
      "properties": {
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "credit", "debit", "pix"] },
        "source": { "type": "string", "enum": ["physical-store", "whatsapp", "instagram"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "cashDetails": {
          "type": "object",
          "properties": {
            "bills": { "type": "object" },
            "coins": { "type": "object" },
            "total": { "type": "number" }
          }
        }
      },
      "required": ["sellerId", "amount", "paymentMethod", "source", "timestamp"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Sales goal tracking",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "target": { "type": "number" },
        "current": { "type": "number" },
        "status": { "type": "string", "enum": ["on-track", "behind", "completed"] }
      },
      "required": ["title", "target", "current"]
    },
    "Seller": {
      "title": "Seller",
      "description": "Registered seller profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "goal": { "type": "number" },
        "observations": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "goal"]
    },
    "CashMovement": {
      "title": "Cash Movement",
      "description": "A cash bleed (sangria) or reinforcement record",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["sangria", "reforco"] },
        "amount": { "type": "number" },
        "observation": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "cashDetails": {
          "type": "object",
          "properties": {
            "bills": { "type": "object" },
            "coins": { "type": "object" },
            "total": { "type": "number" }
          }
        },
        "userId": { "type": "string" },
        "userName": { "type": "string" }
      },
      "required": ["type", "amount", "timestamp", "userId"]
    },
    "CashSession": {
      "title": "Cash Session",
      "description": "A cash register opening or closing session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "openingTimestamp": { "type": "string", "format": "date-time" },
        "openingAmount": { "type": "number" },
        "openingDetails": { "type": "object" },
        "closingTimestamp": { "type": "string", "format": "date-time" },
        "closingAmount": { "type": "number" },
        "closingDetails": { "type": "object" },
        "expectedAmount": { "type": "number" },
        "difference": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "observations": { "type": "string" }
      },
      "required": ["userId", "openingTimestamp", "openingAmount", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Sales records" },
    "/goals/{goalId}": { "schema": "Goal", "description": "Sales goals" },
    "/sellers/{sellerId}": { "schema": "Seller", "description": "Registered sellers" },
    "/cashMovements/{movementId}": { "schema": "CashMovement", "description": "Cash movements (sangria/reforco)" },
    "/cashSessions/{sessionId}": { "schema": "CashSession", "description": "Cash register sessions" }
  }
}
